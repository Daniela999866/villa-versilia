# ============================================
# VILLA VERSILIA - Environment Variables
# ============================================
# Copia questo file in .env.local e compila tutti i valori

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- STRIPE ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# --- EMAIL (Nodemailer - usa Gmail o SendGrid) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tua-email@gmail.com
EMAIL_PASS=tua-app-password
EMAIL_FROM=Villa Versilia Relais <villaversiliarelais@gmail.com>

# --- ADMIN ---
ADMIN_SECRET_KEY=una-chiave-segreta-sicura-min-32-caratteri

# --- SITO ---
NEXT_PUBLIC_SITE_URL=https://www.villaversilia.it
NEXT_PUBLIC_WHATSAPP_NUMBER=393755455596
NEXT_PUBLIC_CONTACT_EMAIL=villaversiliarelais@gmail.com
NEXT_PUBLIC_ADDRESS=Via Adolfo Massei 28, Lido di Camaiore (LU), Versilia, Toscana

# --- GOOGLE MAPS ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# --- PREZZI DEFAULT (euro/notte) ---
DEFAULT_PRICE_WEEKDAY=180
DEFAULT_PRICE_WEEKEND=220
DEFAULT_PRICE_PEAK=280
CLEANING_FEE=80
DEPOSIT_PERCENTAGE=30
